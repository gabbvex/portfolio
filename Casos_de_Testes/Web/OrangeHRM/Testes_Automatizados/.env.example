# ============================================================
# Playwright - Variaveis de Ambiente (EXEMPLO)
# ============================================================
# Copie este arquivo para .env e ajuste os valores.
# NAO commite o .env no repositorio. Commite apenas este .env.example.
# ============================================================

# --- Aplicacao ---
BASE_URL=https://opensource-demo.orangehrmlive.com

# --- Browser ---
HEADLESS=true

# --- Timeouts (em milissegundos) ---
PLAYWRIGHT_TIMEOUT=30000
PLAYWRIGHT_EXPECT_TIMEOUT=5000

# --- CI / Retries / Workers ---
# CI=true
# PLAYWRIGHT_RETRIES=2
# PLAYWRIGHT_WORKERS=1

# --- Evidencias (true = ligado, false = desligado) ---
TRACE_ON_RETRY=true
VIDEO_ON_FAILURE=false
SCREENSHOT_ON_FAILURE=true

# --- Reports ---
REPORT_OUTPUT_DIR=reports/html-report
JSON_REPORT_OUTPUT=reports/json-report/results.json